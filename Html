function approveInbox(id){
  const idx=inbox.findIndex(r=>r.id===id); if(idx===-1) return;
  inbox[idx].status='approved';
  const req=inbox[idx];
  const entry={...req, status:undefined, createdAt:Date.now()};
  
  if(req.clientType==='buyer') buyers.unshift(entry);
  else sellers.unshift(entry);
  
  toast('✅ تم اعتماد الطلب ونقله بنجاح');
  closeOverlay('approveOverlay'); save(); syncCloudInbox();
}

function reApproveInbox(id){
  const req=inbox.find(r=>r.id===id); if(!req) return;
  const entry={...req, status:undefined, createdAt:Date.now()};
  
  if(req.clientType==='buyer'){
    if(!buyers.some(b=>b.id===id)) buyers.unshift(entry);
  } else {
    if(!sellers.some(s=>s.id===id)) sellers.unshift(entry);
  }
  toast('🔄 تم إعادة نقل العرض للقائمة الرئيسية');
  closeOverlay('approveOverlay'); save();
}

function rejectInbox(id){
  const idx=inbox.findIndex(r=>r.id===id); if(idx===-1) return;
  inbox[idx].status='rejected';
  toast('❌ تم رفض الطلب');
  closeOverlay('approveOverlay'); save(); syncCloudInbox();
}

function clearProcessed(){
  if(!confirm('⚠️ هل أنت متأكد من حذف جميع الطلبات المعتمدة والمرفوضة؟')) return;
  inbox=inbox.filter(i=>i.status==='pending');
  toast('🗑️ تم تنظيف صندوق الوارد');
  save(); syncCloudInbox();
}

