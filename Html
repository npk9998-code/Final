function exportJSON(){
  const out={ sellers:sellers, buyers:buyers, exportedAt:Date.now() };
  dl(JSON.stringify(out,null,2), 'application/json', 'عقارات_نسخة_احتياطية_'+dateStr()+'.json');
  toast('📥 تم تصدير ملف الـ JSON بنجاح');
}

function openImport(){ document.getElementById('importOverlay').style.display='flex'; }

function doImport(input){
  if(!input.files||!input.files[0]) return;
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      const data=JSON.parse(e.target.result);
      let addedS=0, addedB=0;
      if(data.sellers && Array.isArray(data.sellers)){
        data.sellers.forEach(s=>{ if(!sellers.some(x=>x.id===s.id)){ sellers.push(s); addedS++; } });
      }
      if(data.buyers && Array.isArray(data.buyers)){
        data.buyers.forEach(b=>{ if(!buyers.some(x=>x.id===b.id)){ buyers.push(b); addedB++; } });
      }
      toast('✅ استيراد ناجح (تم دمج +'+addedS+' بائع، +'+addedB+' مشتري)');
      closeOverlay('importOverlay'); save();
    }catch(err){ toast('❌ ملف JSON غير صالح أو تالف','err'); }
  };
  reader.readAsText(input.files[0]);
  input.value='';
}

function exportCSV(){
  const isBuyer=mode==='buyers';
  const data=currentData();
  let csv='\ufeff'; // UTF-8 BOM
  
  if(!isBuyer){
    csv+='الرقم,الاسم,الجوال,المدينة,الاتجاه,الحي,النوع,المساحة,عرض الشارع,السعر,قابل للتفاوض,الملاحظات\n';
    data.forEach((o,i)=>{
      csv+=[i+1, o.sellerName, o.sellerPhone, o.city||'الرياض', o.direction, o.neighborhood, o.propertyType, o.area, o.streetWidth, o.price, o.negotiable?'نعم':'لا', o.notes]
        .map(v=>'"'+String(v||'').replace(/"/g,'""')+'"').join(',')+'\n';
    });
  } else {
    csv+='الرقم,الاسم,الجوال,المدينة,الاتجاه المفضل,الحي,النوع المطلوب,الميزانية الأدنى,الميزانية الأعلى,المساحة الأدنى,المساحة الأعلى,الملاحظات\n';
    data.forEach((o,i)=>{
      csv+=[i+1, o.sellerName, o.sellerPhone, o.city||'الرياض', o.direction, o.neighborhood, o.propertyType, o.budgetMin, o.budgetMax, o.areaMin, o.areaMax, o.notes]
        .map(v=>'"'+String(v||'').replace(/"/g,'""')+'"').join(',')+'\n';
    });
  }
  
  const fileName=isBuyer?'طلبات_المشترين_':'عروض_البائعين_';
  dl(csv, 'text/csv;charset=utf-8;', fileName+dateStr()+'.csv');
  toast('📊 تم تحميل ملف الـ CSV بنجاح');
}

