// ══════════════════════════════════════════════════
//  MATCHING TAB (ALGORITHM)
// ══════════════════════════════════════════════════
function renderMatching(){
  let h='<div style="padding-bottom:18px"><div class="sec-title">🤝 مطابقة العروض والطلبات الذكية</div>'
    +'<div style="color:var(--muted);font-size:11px;margin-bottom:14px;line-height:1.5">'
    +'يقوم النظام تلقائياً بتحليل ومطابقة عروض البائعين مع طلبات المشترين بناءً على (المدينة، نوع العقار، الاتجاه، المساحة، والسعر).'
    +'</div>';

  if(!sellers.length || !buyers.length){
    return h+'<div class="empty"><div class="e-ic">🤝</div><div class="e-t">لا يمكن إجراء المطابقة</div>'
      +'<div class="e-s">يجب توفر (عرض بائع واحد وطلب مشتري واحد على الأقل) لإجراء التحليل.</div></div></div>';
  }

  let matches=[];
  sellers.forEach(s=>{
    buyers.forEach(b=>{
      let score=0, maxScore=0, tags=[];
      
      // 1. City Check (Critical)
      maxScore+=30;
      if((s.city||'الرياض')===(b.city||'الرياض')){ score+=30; tags.push('🏙️ نفس المدينة'); }
      else return; // Skip if different cities

      // 2. Property Type Check (Critical)
      maxScore+=30;
      if(s.propertyType && b.propertyType && s.propertyType===b.propertyType){ score+=30; tags.push('🏗️ تطابق النوع ('+s.propertyType+')'); }
      
      // 3. Direction Check
      if(b.direction){
        maxScore+=15;
        if(s.direction===b.direction){ score+=15; tags.push('📍 نفس الاتجاه ('+s.direction+')'); }
      }

      // 4. Budget / Price Check
      maxScore+=25;
      const price=numVal(s.price);
      const bMin=b.budgetMin?Number(b.budgetMin):0;
      const bMax=b.budgetMax?Number(b.budgetMax):Infinity;
      if(price>=bMin && price<=bMax){ score+=25; tags.push('💰 السعر مناسب للميزانية'); }
      else if(price>bMax && s.negotiable){
        const diffPct=((price-bMax)/bMax)*100;
        if(diffPct<=15){ score+=15; tags.push('💸 السعر أعلى بقليل (قابل للتفاوض)'); }
      }

      // 5. Area Check
      if(b.areaMin || b.areaMax){
        maxScore+=15;
        const area=Number(s.area||0);
        const aMin=b.areaMin?Number(b.areaMin):0;
        const aMax=b.areaMax?Number(b.areaMax):Infinity;
        if(area>=aMin && area<=aMax){ score+=15; tags.push('📐 المساحة متطابقة'); }
      }

      let pct=Math.round((score/maxScore)*100);
      if(pct>=40){
        matches.push({ seller:s, buyer:b, pct:pct, tags:tags });
      }
    });
  });

  matches.sort((a,b)=>b.pct-a.pct);

  if(!matches.length){
    h+'<div class="empty"><div class="e-ic">🔍</div><div class="e-t">لم يتم العثور على أي تطابق متوافق حالياً</div></div>';
  } else {
    h+='<div style="font-size:11px;color:var(--dim);margin-bottom:8px">'+matches.length+' تطابق ذكي محتمل</div>';
    matches.forEach(m=>{
      const scoreColor=m.pct>=75?'#22c55e':m.pct>=50?'#f59e0b':'#3b82f6';
      h+='<div class="match-card">'
        +'<div style="display:flex;justify-content:space-between;align-items:center">'
        +'<span style="font-size:11px;color:var(--muted)">نسبة التوافق</span>'
        +'<span class="match-score" style="color:'+scoreColor+'">'+m.pct+'%</span>'
        +'</div>'
        +'<div class="match-bar"><div class="match-fill" style="width:'+m.pct+'%;background:'+scoreColor+'"></div></div>'
        
        +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:10px 0;background:rgba(0,0,0,.2);padding:8px;border-radius:8px">'
        +'<div onclick="mode=\'sellers\';openDetail(\''+m.seller.id+'\')" style="cursor:pointer;border-left:1px solid var(--border);padding-left:4px">'
        +'<div style="font-size:10px;color:#f59e0b;font-weight:800">🏷️ عرض البائع</div>'
        +'<div style="font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+x(m.seller.sellerName)+'</div>'
        +'<div style="font-size:11px;color:var(--muted)">'+(m.seller.price?fp(m.seller.price)+' ﷼':'—')+'</div>'
        +'</div>'
        +'<div onclick="mode=\'buyers\';openDetail(\''+m.buyer.id+'\')" style="cursor:pointer;padding-right:4px">'
        +'<div style="font-size:10px;color:#10b981;font-weight:800">🛒 طلب المشتري</div>'
        +'<div style="font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+x(m.buyer.sellerName)+'</div>'
        +'<div style="font-size:11px;color:var(--muted)">إلى '+(m.buyer.budgetMax?fp(m.buyer.budgetMax)+' ﷼':'—')+'</div>'
        +'</div>'
        +'</div>'
        
        +'<div style="margin-top:5px">'+m.tags.map(t=>'<span class="match-tag" style="background:'+scoreColor+'15;color:'+scoreColor+';border:1px solid '+scoreColor+'30">'+t+'</span>').join('')+'</div>'
        +'<div style="display:flex;gap:6px;margin-top:10px">'
        +'<button class="btn wa-btn b-sm" onclick="openMatchContact(\''+m.seller.sellerPhone+'\',\''+m.buyer.sellerPhone+'\',\''+m.seller.propertyType+'\',\''+m.seller.neighborhood+'\')">📱 اتصال جماعي</button>'
        +'</div>'
        +'</div>';
    });
  }
  return h+'</div>';
}

function openMatchContact(sPhone, bPhone, type, neighborhood){
  const msg='مرحباً، بخصوص طلبكم لعقار ('+(type||'')+' في '+(neighborhood||'')+') يتوفر لدينا خيار مطابق ومناسب جداً للتفاصيل المذكورة.';
  window.open('https://wa.me/'+sPhone+'?text='+encodeURIComponent(msg),'_blank');
}

